# Database Configuration - Fly.io Production
DB_HOST=your_mysql_host
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# Application Settings
APP_NAME="TRỌNG TÀI SỐ"
APP_VERSION=2.0.0
APP_ENV=production
APP_DEBUG=false

# Upload Settings
UPLOAD_PATH=uploads/
MAX_FILE_SIZE=5242880

# Tournament Settings
DEFAULT_GROUPS=4
MAX_GROUPS=8
MIN_TEAMS_PER_GROUP=2
MAX_TEAMS_PER_GROUP=8
